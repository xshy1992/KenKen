<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:padding="12dp">

    <TextView
        android:id="@+id/timer_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0:00"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="@color/text_normal"
        android:layout_gravity="center"
        android:layout_marginBottom="8dp"/>

    <com.shy.kenken.view.KenKenView
        android:id="@+id/kenken_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_gravity="center"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:layout_marginBottom="12dp">

        <!-- 草稿按钮 -->
        <LinearLayout
            android:id="@+id/container_pencil"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:minHeight="60dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/btn_bg_normal"
            android:padding="6dp"
            android:layout_marginEnd="6dp"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✏️"
                android:textSize="22sp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="草稿"
                android:textSize="12sp"
                android:textColor="@color/white"/>
        </LinearLayout>

        <!-- 撤销按钮 -->
        <LinearLayout
            android:id="@+id/container_undo"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:minHeight="60dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/btn_bg_normal"
            android:padding="6dp"
            android:layout_marginEnd="6dp"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🧼"
                android:textSize="22sp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="撤销"
                android:textSize="12sp"
                android:textColor="@color/white"/>
        </LinearLayout>

        <!-- 清除按钮 -->
        <LinearLayout
            android:id="@+id/container_clear"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:minHeight="60dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/btn_bg_normal"
            android:padding="6dp"
            android:layout_marginEnd="6dp"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🧹"
                android:textSize="22sp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="清除"
                android:textSize="12sp"
                android:textColor="@color/white"/>
        </LinearLayout>

        <!-- 重置按钮 - 放在最右边 -->
        <LinearLayout
            android:id="@+id/container_reset"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:minHeight="60dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/btn_bg_normal"
            android:padding="6dp"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔄"
                android:textSize="22sp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="重置"
                android:textSize="12sp"
                android:textColor="@color/white"/>
        </LinearLayout>
    </LinearLayout>

    <!-- First row: 1-6 一行6个 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp"
        android:gravity="center">

        <Button
            android:id="@+id/btn_1"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:minHeight="56dp"
            android:layout_weight="1"
            android:text="1"
            android:textSize="24sp"
            android:textColor="@color/white"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/btn_bg_selector"
            android:backgroundTint="@color/primary"/>

        <Button
            android:id="@+id/btn_2"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:minHeight="56dp"
            android:layout_weight="1"
            android:text="2"
            android:textSize="24sp"
            android:textColor="@color/white"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/btn_bg_selector"
            android:backgroundTint="@color/primary"/>

        <Button
            android:id="@+id/btn_3"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:minHeight="56dp"
            android:layout_weight="1"
            android:text="3"
            android:textSize="24sp"
            android:textColor="@color/white"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/btn_bg_selector"
            android:backgroundTint="@color/primary"/>

        <Button
            android:id="@+id/btn_4"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:minHeight="56dp"
            android:layout_weight="1"
            android:text="4"
            android:textSize="24sp"
            android:textColor="@color/white"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/btn_bg_selector"
            android:backgroundTint="@color/primary"/>

        <Button
            android:id="@+id/btn_5"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:minHeight="56dp"
            android:layout_weight="1"
            android:text="5"
            android:textSize="24sp"
            android:textColor="@color/white"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/btn_bg_selector"
            android:backgroundTint="@color/primary"/>

        <Button
            android:id="@+id/btn_6"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:minHeight="56dp"
            android:layout_weight="1"
            android:text="6"
            android:textSize="24sp"
            android:textColor="@color/white"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/btn_bg_selector"
            android:backgroundTint="@color/primary"/>
    </LinearLayout>

    <!-- Second row: 7-9 + 3个占位，总共6个 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="6dp"
        android:gravity="center">

        <Button
            android:id="@+id/btn_7"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:minHeight="56dp"
            android:layout_weight="1"
            android:text="7"
            android:textSize="24sp"
            android:textColor="@color/white"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/btn_bg_selector"
            android:backgroundTint="@color/primary"/>

        <Button
            android:id="@+id/btn_8"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:minHeight="56dp"
            android:layout_weight="1"
            android:text="8"
            android:textSize="24sp"
            android:textColor="@color/white"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/btn_bg_selector"
            android:backgroundTint="@color/primary"/>

        <Button
            android:id="@+id/btn_9"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:minHeight="56dp"
            android:layout_weight="1"
            android:text="9"
            android:textSize="24sp"
            android:textColor="@color/white"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/btn_bg_selector"
            android:backgroundTint="@color/primary"/>

        <!-- 3 empty spacers to fill the row (total 6 columns) -->
        <View
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:background="@color/background"/>
        <View
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:background="@color/background"/>
        <View
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:background="@color/background"/>
    </LinearLayout>

</LinearLayout>
