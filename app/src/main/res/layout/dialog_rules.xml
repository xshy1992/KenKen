<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@color/card_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📖 聪明格 KenKen 游戏规则"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_normal"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="什么是聪明格？"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_normal"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="聪明格（KenKen）是一种起源于日本的数学逻辑益智游戏，结合了数独和算术运算，锻炼你的逻辑思维和计算能力。"
            android:textSize="15sp"
            android:textColor="@color/text_light"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="游戏规则："
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_normal"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1️⃣ 在 N×N 的格子中填入 1 到 N 的数字"
            android:textSize="15sp"
            android:textColor="@color/text_light"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2️⃣ 每一行、每一列的数字不能重复（类似数独规则）"
            android:textSize="15sp"
            android:textColor="@color/text_light"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="3️⃣ 每个粗框区域左上角会标注「目标数+运算符」，区域内所有数字运算结果必须等于目标数"
            android:textSize="15sp"
            android:textColor="@color/text_light"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="4️⃣ 单格粗框直接填标注的数字"
            android:textSize="15sp"
            android:textColor="@color/text_light"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="3×3 示例图："
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_normal"
            android:layout_marginBottom="8dp"/>

        <!-- 3×3 示例图 -->
        <ImageView
            android:id="@+id/iv_example"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:scaleType="centerInside"
            android:contentDescription="3x3示例图"
            android:src="@drawable/kenken_example_3x3"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="玩法技巧："
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_normal"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="• 先填只有一个格子的粗框"
            android:textSize="15sp"
            android:textColor="@color/text_light"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="• 利用行列不重复规则排除不可能的数字"
            android:textSize="15sp"
            android:textColor="@color/text_light"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="• 草稿模式可以帮你标记候选数字"
            android:textSize="15sp"
            android:textColor="@color/text_light"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="4dp"/>

    </LinearLayout>

</ScrollView>
